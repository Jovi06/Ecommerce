<%- include('../partials/header') %>

    <main class="page-content admin-page">
        <div class="admin-container">
            <div class="admin-header">
                <h1 class="section-title">MANAGE COUPONS</h1>
                <nav class="admin-nav">
                    <a href="/admin/dashboard" class="btn btn-secondary btn-sm">Dashboard</a>
                    <a href="/admin/products" class="btn btn-secondary btn-sm">Products</a>
                    <a href="/admin/orders" class="btn btn-secondary btn-sm">Orders</a>
                    <a href="/admin/users" class="btn btn-secondary btn-sm">Users</a>
                    <a href="/admin/coupons" class="btn btn-secondary btn-sm active">Coupons</a>
                </nav>
            </div>

            <% if (error) { %>
                <div class="alert alert-error">
                    <%= error %>
                </div>
                <% } %>
                    <% if (success) { %>
                        <div class="alert alert-success">
                            <%= success %>
                        </div>
                        <% } %>

                            <!-- Add Coupon Form -->
                            <div class="admin-section" style="margin-bottom:32px;">
                                <h2 class="cart-summary-title">Add New Coupon</h2>
                                <form action="/admin/coupons" method="POST" class="admin-form"
                                    style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:12px;align-items:end;">
                                    <div class="form-group" style="margin:0;">
                                        <label for="code">Code</label>
                                        <input type="text" id="code" name="code" placeholder="e.g. SAVE20" required
                                            class="form-input" style="text-transform:uppercase;">
                                    </div>
                                    <div class="form-group" style="margin:0;">
                                        <label for="discountType">Type</label>
                                        <select id="discountType" name="discountType" class="form-input">
                                            <option value="percentage">Percentage (%)</option>
                                            <option value="fixed">Fixed ($)</option>
                                        </select>
                                    </div>
                                    <div class="form-group" style="margin:0;">
                                        <label for="discountValue">Value</label>
                                        <input type="number" id="discountValue" name="discountValue" placeholder="20"
                                            step="0.01" required class="form-input">
                                    </div>
                                    <div class="form-group" style="margin:0;">
                                        <label for="minOrderAmount">Min Order ($)</label>
                                        <input type="number" id="minOrderAmount" name="minOrderAmount" placeholder="50"
                                            step="0.01" class="form-input">
                                    </div>
                                    <div class="form-group" style="margin:0;">
                                        <label for="maxUses">Max Uses</label>
                                        <input type="number" id="maxUses" name="maxUses" placeholder="100"
                                            class="form-input">
                                    </div>
                                    <div class="form-group" style="margin:0;">
                                        <label for="expiresAt">Expires At</label>
                                        <input type="date" id="expiresAt" name="expiresAt" class="form-input">
                                    </div>
                                    <button type="submit" class="btn btn-primary btn-sm">Add Coupon</button>
                                </form>
                            </div>

                            <!-- Coupons Table -->
                            <% if (coupons && coupons.length> 0) { %>
                                <div class="admin-table-wrapper">
                                    <table class="admin-table">
                                        <thead>
                                            <tr>
                                                <th>Code</th>
                                                <th>Type</th>
                                                <th>Value</th>
                                                <th>Min Order</th>
                                                <th>Uses</th>
                                                <th>Expires</th>
                                                <th>Actions</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <% coupons.forEach(coupon=> { %>
                                                <tr>
                                                    <td><strong>
                                                            <%= coupon.code %>
                                                        </strong></td>
                                                    <td>
                                                        <%= coupon.discountType %>
                                                    </td>
                                                    <td>
                                                        <%= coupon.discountType==='percentage' ? coupon.discountValue
                                                            + '%' : '$' + coupon.discountValue %>
                                                    </td>
                                                    <td>
                                                        <%= coupon.minOrderAmount ? '$' + coupon.minOrderAmount : '—' %>
                                                    </td>
                                                    <td>
                                                        <%= coupon.usedCount || 0 %> / <%= coupon.maxUses || '∞' %>
                                                    </td>
                                                    <td>
                                                        <%= coupon.expiresAt ? new
                                                            Date(coupon.expiresAt).toLocaleDateString() : 'Never' %>
                                                    </td>
                                                    <td>
                                                        <form action="/admin/coupons/delete" method="POST"
                                                            onsubmit="return confirm('Delete this coupon?')">
                                                            <input type="hidden" name="couponId"
                                                                value="<%= coupon._id %>">
                                                            <button type="submit" class="btn btn-sm"
                                                                style="background:#dc3545;color:#fff;border:none;">Delete</button>
                                                        </form>
                                                    </td>
                                                </tr>
                                                <% }) %>
                                        </tbody>
                                    </table>
                                </div>
                                <% } else { %>
                                    <div class="empty-state">
                                        <p>No coupons yet. Add one above.</p>
                                    </div>
                                    <% } %>
        </div>
    </main>

    <%- include('../partials/footer') %>