<%- include('partials/header') %>

    <main class="page-content checkout-page">
        <div class="checkout-container">
            <h1 class="section-title">CHECKOUT</h1>

            <div class="cart-layout">
                <div class="checkout-items">
                    <!-- Shipping Address Form -->
                    <h2 class="cart-summary-title">Shipping Address</h2>
                    <form action="/order" method="POST" id="checkout-form" class="checkout-form">
                        <div class="form-group">
                            <label for="fullName">Full Name</label>
                            <input type="text" id="fullName" name="fullName" required class="form-input"
                                value="<%= user ? user.name : '' %>" placeholder="John Doe">
                        </div>
                        <div class="form-group">
                            <label for="address">Address</label>
                            <input type="text" id="address" name="address" required class="form-input"
                                placeholder="123 Nike Street">
                        </div>
                        <div class="form-row">
                            <div class="form-group">
                                <label for="city">City</label>
                                <input type="text" id="city" name="city" required class="form-input"
                                    placeholder="New York">
                            </div>
                            <div class="form-group">
                                <label for="state">State</label>
                                <input type="text" id="state" name="state" required class="form-input" placeholder="NY">
                            </div>
                            <div class="form-group">
                                <label for="zip">ZIP Code</label>
                                <input type="text" id="zip" name="zip" required class="form-input" placeholder="10001">
                            </div>
                        </div>
                        <div class="form-group">
                            <label for="phone">Phone</label>
                            <input type="tel" id="phone" name="phone" class="form-input"
                                placeholder="+1 (555) 123-4567">
                        </div>

                        <h2 class="cart-summary-title" style="margin-top:24px;">Order Summary</h2>
                        <% cart.forEach(item=> { %>
                            <div class="cart-item cart-item-compact">
                                <div class="cart-item-image">
                                    <img src="<%= item.image %>" alt="<%= item.name %>">
                                </div>
                                <div class="cart-item-details">
                                    <h3 class="cart-item-name">
                                        <%= item.name %>
                                    </h3>
                                    <p class="cart-item-price">$<%= item.price %> x <%= item.quantity %>
                                    </p>
                                </div>
                                <div class="cart-item-subtotal">
                                    $<%= (item.price * item.quantity).toFixed(2) %>
                                </div>
                            </div>
                            <% }) %>
                    </form>
                </div>

                <div class="cart-summary">
                    <h2 class="cart-summary-title">Total</h2>
                    <div class="cart-summary-row">
                        <span>Subtotal</span>
                        <span>$<%= total.toFixed(2) %></span>
                    </div>
                    <div class="cart-summary-row">
                        <span>Shipping</span>
                        <span>Free</span>
                    </div>
                    <div class="cart-summary-row cart-summary-total">
                        <span>Total</span>
                        <span>$<%= total.toFixed(2) %></span>
                    </div>
                    <button type="submit" form="checkout-form" class="btn btn-primary btn-full">Place Order</button>
                </div>
            </div>
        </div>
    </main>

    <%- include('partials/footer') %>