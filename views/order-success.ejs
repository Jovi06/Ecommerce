<%- include('partials/header') %>

    <main class="page-content auth-page">
        <div class="auth-container" style="text-align: center;">
            <div class="order-success-icon">
                <svg width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="#111" stroke-width="1.5">
                    <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" />
                    <polyline points="22 4 12 14.01 9 11.01" />
                </svg>
            </div>
            <h1 class="auth-title">ORDER CONFIRMED</h1>
            <p class="auth-subtitle" style="margin-bottom: 16px;">Thank you for your order!</p>
            <p style="color: #757575; margin-bottom: 8px;">Order ID: <strong>
                    <%= order._id %>
                </strong></p>
            <p style="color: #757575; margin-bottom: 32px;">Total: <strong>$<%= order.total.toFixed(2) %></strong></p>
            <a href="/" class="btn btn-primary">Continue Shopping</a>
        </div>
    </main>

    <%- include('partials/footer') %>