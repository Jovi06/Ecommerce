<%- include('partials/header') %>

    <main class="page-content auth-page">
        <div class="auth-container">
            <div class="auth-brand">
                <svg viewBox="0 0 69 32" fill="#111" xmlns="http://www.w3.org/2000/svg" width="64">
                    <path
                        d="M68.56 4.05C57.31 10.1 44.8 18.47 35.81 26.37c-4.24 3.73-7.74 6.7-10.48 6.7-3.59 0-4.65-4.07-5.13-7.03L16.11 4.74C15.49 1.47 14.5.34 12.74.34c-1.47 0-4.34 1.92-7.53 4.34L2.75 1.94C7.28-1.87 12.2-.2 14.92-.2c4.62 0 6.1 3.07 7.01 7.66l3.44 18.78c1.09-.98 3.56-3.35 7.76-7.03C40.96 12.2 54.8 3.44 62.26 0l6.3 4.05z" />
                </svg>
                <h1 class="auth-title">YOUR ACCOUNT</h1>
                <p class="auth-subtitle">Sign in to Nike</p>
            </div>

            <% if (error) { %>
                <div class="alert alert-error">
                    <%= error %>
                </div>
                <% } %>

                    <form class="auth-form" action="/login" method="POST">
                        <div class="form-group">
                            <label for="email">Email address</label>
                            <input type="email" id="email" name="email" placeholder="Enter your email" required>
                        </div>
                        <div class="form-group">
                            <label for="password">Password</label>
                            <input type="password" id="password" name="password" placeholder="Enter your password"
                                required>
                        </div>
                        <button type="submit" class="btn btn-primary btn-full">Sign In</button>
                    </form>

                    <p class="auth-switch">
                        Not a member? <a href="/signup">Join Us</a>
                    </p>
        </div>
    </main>

    <%- include('partials/footer') %>